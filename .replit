entrypoint = "manage.py"
modules = ["python-3.12"]

run = "bash scripts/replit_start.sh"

[deployment]
run = ["bash", "scripts/replit_start.sh"]
deploymentTarget = "autoscale"

[nix]
packages = ["cacert", "freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "pgadmin4", "tcl", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python manage.py migrate --noinput && python manage.py collectstatic --noinput && gunicorn django_finances.wsgi:application --bind 0.0.0.0:5000"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

